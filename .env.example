# .env.example — Copy this file to .env and fill in real values.
# .env is git-ignored; never commit actual secrets.
#
# How secrets are loaded:
#   core/config.py calls `dotenv.load_dotenv()` at import time, which reads
#   .env from the project root.  Every module that imports from core.config
#   will therefore have access to these values via the constants below:
#
#     GEMINI_API_KEY  = os.environ.get("GEMINI_API_KEY", "")
#     GEMINI_MODEL    = os.environ.get("GEMINI_MODEL", "gemini-flash-latest")
#     CENSUS_API_KEY  = os.environ.get("CENSUS_API_KEY", "")
#     MASTER_USERNAME = os.environ.get("MASTER_USERNAME", "")
#     MASTER_PASSWORD = os.environ.get("MASTER_PASSWORD", "")

# Google Gemini REST API key (required for NL→SQL chat feature only).
# Obtain at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the default Gemini model (e.g. gemini-3.5-flash).
# Leave blank to use the hard-coded default in core/config.py (gemini-3.1-flash-lite).
GEMINI_MODEL=

# Optional: client-side cloud rate limits (chat auto-falls back to local gemma
# when exceeded, avoiding free-tier 429s). Leave blank to use the code defaults
# in core/config.py (5/min, 200/day). Gemini 3.1 Flash-Lite free tier is
# ~15 req/min and 1,000 req/day — set GEMINI_DAILY_LIMIT=1000 to use the full
# daily budget. Note: Google resets RPD at midnight Pacific; this app's counter
# resets at local midnight.
GEMINI_RPM_LIMIT=
GEMINI_DAILY_LIMIT=

# US Census Bureau API key (required for ACS5 population data).
# Obtain free key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Single operator credentials for the demo login gate.
# Replace these placeholders in your local .env; never commit real values.
MASTER_USERNAME=admin
MASTER_PASSWORD=changeme
